# Slim runtime image — built by CI after cross-compilation.
FROM ubuntu:24.04

RUN DEBIAN_FRONTEND=noninteractive apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    libbsd0 \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r connector && useradd -r -g connector -s /sbin/nologin connector

ARG BINARY_PATH=target/aarch64-unknown-linux-gnu/release/aeron-driver
COPY ${BINARY_PATH} /usr/local/bin/aeron-driver

USER connector
ENTRYPOINT ["/usr/local/bin/aeron-driver"]
